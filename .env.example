# Copy this file to ".env" and fill in your key.
#   cp .env.example .env

# --- OpenAI / GPT ---------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here
# Model id to benchmark. Change freely (e.g. gpt-5.5, gpt-5.4, gpt-4o).
OPENAI_MODEL=gpt-5.5
# Optional: override the API base (Azure, proxy, local gateway, etc.)
# OPENAI_BASE_URL=

# --- (later) other providers ---------------------------------------------
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# QWEN_API_KEY=
